generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Os campos usam String no banco; TypeScript garante os valores via tipos em atlas/types/index.ts.

model AtlasItem {
  id          String   @id @default(cuid())
  slug        String?  @unique
  title       String

  // ItemType: PAGE | PERSON | WORK | OBJECT | CONCEPT | COURSE | READING | REPERTOIRE | NOTA | AULA | PARTITURA
  type        String   @default("PAGE")

  // AreaType: ACADEMIA | ARTES | CULTURA | STUDIO | OBRAS | PESSOAS | COMPUTACAO | AULAS | COMPASS | DIARIO | PERFIL | NOTAS | ATLAS
  area        String   @default("ATLAS")

  // Hemisphere: PORTAL | COMPASS
  hemisphere  String   @default("PORTAL")

  // StatusType: ACTIVE | BACKLOG | COMPLETED | ARCHIVED | FAVORITE
  status      String   @default("ACTIVE")

  // Flags rápidas (complementam status)
  isFavorite  Boolean  @default(false)
  isPinned    Boolean  @default(false)

  // Conteúdo BlockNote serializado como string JSON
  content     String?

  // Caminho para o arquivo .md espelho em /content
  contentPath String?

  // Metadados flexíveis (JSON serializado): período, localização, ISBN, etc.
  metadata    String?

  // URL da imagem de capa ou retrato
  coverImage  String?

  // Geolocalização: "lat,lon" ex: "-22.9,-43.17"
  location    String?

  // ViewType: LIST | TABLE | KANBAN | GALLERY | ATLAS_MAP | SHELVES | INDEX | AUTORES | PARTITURAS | CURSOS | REPERTORIO | READINGS
  viewType    String   @default("LIST")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tags          Tag[]           @relation("AtlasItemTags")
  relationsFrom AtlasRelation[] @relation("RelationFrom")
  relationsTo   AtlasRelation[] @relation("RelationTo")
  interests     UserInterest[]
  posts         Post[]
}

// Compass — entradas do diário com metadados estruturados
model JournalEntry {
  id          String   @id @default(cuid())

  // Data da entrada no formato "YYYY-MM-DD"
  date        String   @unique

  // Conteúdo BlockNote serializado como JSON string
  content     String?

  // Nível de energia: 1=Exausto 2=Pesado 3=Equilibrado 4=Energizado 5=Pleno
  energy      Int      @default(3)

  // Intenção do dia (texto curto)
  intention   String?

  // Humor predominante (texto livre)
  mood        String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Tag {
  id    String      @id @default(cuid())
  name  String      @unique
  color String      @default("#C8A45A")
  items AtlasItem[] @relation("AtlasItemTags")
}

// Relações dirigidas entre itens do Atlas
model AtlasRelation {
  id           String    @id @default(cuid())
  fromItem     AtlasItem @relation("RelationFrom", fields: [fromItemId], references: [id], onDelete: Cascade)
  fromItemId   String
  toItem       AtlasItem @relation("RelationTo", fields: [toItemId], references: [id], onDelete: Cascade)
  toItemId     String
  // Exemplos: "inspira", "parte-de", "contradiz", "autor-de", "referencia", "influenciou"
  relationType String
  createdAt    DateTime  @default(now())
}

// Compass — disciplinas e tracker de estudos
model StudyDiscipline {
  id          String        @id @default(cuid())
  name        String
  code        String        @default("")   // ex: "DES-320"
  professor   String?
  semester    String        @default("")   // ex: "2026-1"
  totalHours  Int           @default(60)
  color       String        @default("#C8A45A")
  createdAt   DateTime      @default(now())
  sessions    StudySession[]
}

model StudySession {
  id           String           @id @default(cuid())
  disciplineId String
  discipline   StudyDiscipline  @relation(fields: [disciplineId], references: [id], onDelete: Cascade)
  date         DateTime         @default(now())
  durationMin  Int              @default(30)
  note         String?
}

// Compass — metas e intenções
model Goal {
  id          String   @id @default(cuid())
  title       String
  description String?
  // "short" | "long"
  horizon     String   @default("short")
  // "active" | "completed" | "paused"
  status      String   @default("active")
  dueDate     DateTime?
  progress    Int      @default(0)          // 0–100
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// RSS — fontes configuradas pelo usuário
model RSSFeed {
  id        String     @id @default(cuid())
  url       String     @unique
  label     String     @default("")
  area      String     @default("ATLAS")
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  items     RSSItem[]
}

// RSS — itens em cache (atualiza quando há conexão)
model RSSItem {
  id          String   @id @default(cuid())
  feedId      String
  feed        RSSFeed  @relation(fields: [feedId], references: [id], onDelete: Cascade)
  guid        String   @unique
  title       String
  link        String
  summary     String?
  author      String?
  publishedAt DateTime
  cachedAt    DateTime @default(now())
}

// ─── SOCIAL ──────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  displayName  String
  passwordHash String
  bio          String?
  avatarUrl    String?
  // Cor de destaque do perfil (hex)
  accentColor  String   @default("#C8A45A")
  // ID permanente nunca muda, mesmo que username ou displayName sejam alterados
  invitedById  String?
  invitedBy    User?    @relation("InvitedBy", fields: [invitedById], references: [id])
  invitees     User[]   @relation("InvitedBy")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  following               Follow[]                  @relation("UserFollowing")
  followers               Follow[]                  @relation("UserFollowers")
  tickets                 SolarTicket[]             @relation("TicketOwner")
  ticketsGiven            SolarTicket[]             @relation("TicketGiver")
  tokens                  UserToken[]
  interests               UserInterest[]
  posts                   Post[]
  likes                   PostLike[]
  userTags                UserTag[]
  hostedEvents            Event[]                   @relation("EventHost")
  eventRequests           EventRequest[]            @relation("EventRequests")
  eventMessages           EventMessage[]            @relation("EventMessages")
  conversationMemberships ConversationParticipant[] @relation("ConvParticipants")
  sentMessages            Message[]                 @relation("MessageSender")
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  @@unique([followerId, followingId])
}

// Tickets Solares — moeda social do Portal Solar
model SolarTicket {
  id        String    @id @default(cuid())
  ownerId   String
  owner     User      @relation("TicketOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  giverId   String?
  giver     User?     @relation("TicketGiver", fields: [giverId], references: [id])
  // STANDARD | GOLDEN | FOUNDER | EVENT
  type      String    @default("STANDARD")
  isUsed    Boolean   @default(false)
  usedAt    DateTime?
  note      String?
  createdAt DateTime  @default(now())
}

// Tokens colecionáveis do metaverso
model UserToken {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // AVATAR | BADGE | MONUMENT | FRAME | EFFECT | BONECO
  tokenType   String
  name        String
  description String?
  imageUrl    String?
  // JSON — configurações de customização (cor, acessórios, etc.)
  data        String?
  // COMMON | RARE | EPIC | LEGENDARY
  rarity      String   @default("COMMON")
  isEquipped  Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// Interesses — Atlas items vinculados ao perfil do usuário
model UserInterest {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  atlasItemId String
  atlasItem   AtlasItem @relation(fields: [atlasItemId], references: [id], onDelete: Cascade)
  // 1–5
  rating      Int       @default(5)
  note        String?
  createdAt   DateTime  @default(now())
  @@unique([userId, atlasItemId])
}

// Feed social — posts, recomendações, descobertas
model Post {
  id          String     @id @default(cuid())
  authorId    String
  author      User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content     String
  // TEXT | RECOMMENDATION | DISCOVERY | REVIEW
  type        String     @default("TEXT")
  atlasItemId String?
  atlasItem   AtlasItem? @relation(fields: [atlasItemId], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  likes       PostLike[]
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@unique([postId, userId])
}

// ─── QUADRO MUNDIAL ───────────────────────────────────────────────────────────

// Quadro Mundial — avisos, eventos, obras e descobertas
model WorldNotice {
  id        String   @id @default(cuid())
  title     String
  body      String

  // NoticeType: OBRA | AVISO | EVENTO | DESCOBERTA | HOMENAGEM | CITACAO
  type      String   @default("AVISO")

  // AreaType (mesmo enum do Atlas)
  area      String   @default("ATLAS")

  author    String?
  sourceUrl String?
  isPinned  Boolean  @default(false)
  expiresAt DateTime?
  createdAt DateTime @default(now())
}

// ─── TAGS LIVRES DE INTERESSE ─────────────────────────────────────────────────

model UserTag {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tag       String   // "espiritualidade" | "botânica" | "wicca" | livre
  createdAt DateTime @default(now())
  @@unique([userId, tag])
}

// ─── EVENTOS / ENCONTROS ──────────────────────────────────────────────────────

model Event {
  id           String         @id @default(cuid())
  hostId       String
  host         User           @relation("EventHost", fields: [hostId], references: [id])
  title        String
  description  String?
  date         DateTime
  city         String?        // público
  neighborhood String?        // público
  address      String?        // PRIVADO — visível só a participantes aceitos
  maxGuests    Int            @default(6)
  // OPEN | CLOSED | CANCELLED | ENDED
  status       String         @default("OPEN")
  tags         String         @default("[]") // JSON array de strings
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  requests     EventRequest[]
  messages     EventMessage[]
}

model EventRequest {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("EventRequests", fields: [userId], references: [id])
  // PENDING | ACCEPTED | REJECTED
  status    String   @default("PENDING")
  note      String?  // apresentação ao host
  createdAt DateTime @default(now())
  @@unique([eventId, userId])
}

model EventMessage {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("EventMessages", fields: [userId], references: [id])
  content   String
  createdAt DateTime @default(now())
}

// ─── MENSAGENS / CONVERSAS ────────────────────────────────────────────────────

model Conversation {
  id           String                    @id @default(cuid())
  name         String?                   // null = DM, string = nome do grupo
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation("ConvParticipants", fields: [userId], references: [id])
  lastReadAt     DateTime?
  createdAt      DateTime     @default(now())
  @@unique([conversationId, userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("MessageSender", fields: [senderId], references: [id])
  content        String
  createdAt      DateTime     @default(now())
}
