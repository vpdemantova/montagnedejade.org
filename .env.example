# Neon Postgres (pooled) — obter em neon.tech
DATABASE_URL="postgresql://user:pass@host/dbname?sslmode=require"

# Neon Postgres (direct, para migrations) — obter em neon.tech
DIRECT_URL="postgresql://user:pass@host/dbname?sslmode=require"

# IA
GEMINI_API_KEY=
REPLICATE_API_TOKEN=

# Auth — defina valores aleatórios e seguros
AUTH_PASSWORD=sua-senha-aqui
AUTH_SECRET=string-aleatoria-longa-aqui
